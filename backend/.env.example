# ──────────────────────────────────────────────
#  GullyCricket — Environment Variables
#  Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Supabase — get from: Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE

# Server
PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed origins
# For local dev: http://localhost:8080,http://127.0.0.1:8080
# For production: https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# API secret for admin write operations (choose any strong random string)
# Admin panel will include this in X-Admin-Token header
ADMIN_SECRET=change_this_to_a_strong_random_secret_string
